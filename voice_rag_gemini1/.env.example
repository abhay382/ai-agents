# ─────────────────────────────────────────────────────────────
#  Voice RAG Agent  —  Gemini edition  —  .env config
#  Copy this file to .env and fill in your key
# ─────────────────────────────────────────────────────────────

# Required: Get FREE from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model selection
# gemini-2.0-flash      ← fastest, best for real-time voice (recommended)
# gemini-1.5-flash      ← also fast, slightly older
# gemini-1.5-pro        ← most capable, slower
GEMINI_MODEL=gemini-2.0-flash

# Agent behaviour
AGENT_NAME=Jarvis
AGENT_VOICE_RATE=175          # TTS words per minute
RAG_TOP_K=4                   # Knowledge chunks to retrieve

# Whisper STT model (tiny=fastest, base=balanced, small/medium=accurate)
WHISPER_MODEL=base
